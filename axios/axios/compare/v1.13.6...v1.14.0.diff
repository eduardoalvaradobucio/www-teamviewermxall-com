+    expect(downloadProgressSpy).not.toHaveBeenCalled();
+    expect(request.getListenerCount('progress', 'request')).toBe(1);
+    expect(request.getListenerCount('progress', 'upload')).toBe(1);
+
+    request.respondWith({
