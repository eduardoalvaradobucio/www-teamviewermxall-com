+    const instance = axios.create();
+    const instanceInterceptorId = instance.interceptors.request.use((config) => {
+      config.bar = true;
+      return config;
+    });
+
+    try {
+      const responsePromise = instance.get('/foo');
+      const request = await waitForRequest();
+
+      request.respondWith({
