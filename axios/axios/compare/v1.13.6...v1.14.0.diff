+
+  it('should pick suitable adapter from the list', () => {
+    const adapter = () => {};
+
+    Object.assign(adapters.adapters, {
+      foo: false,
+      bar: null,
+      baz: adapter,
+    });
+
+    assert.strictEqual(adapters.getAdapter(['foo', 'bar', 'baz']), adapter);
+  });
+});
