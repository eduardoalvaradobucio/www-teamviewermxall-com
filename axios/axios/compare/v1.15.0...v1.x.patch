+import Splide from '@splidejs/splide';
+import { onMounted } from 'vue';
+import allSponsors from '../data/sponsors.json';
+
+onMounted(() => {
+  new Splide(
+    '.splide',
+    {
+      type: 'loop',
+      autoplay: true,
+      interval: 3000,
+      perPage: 5,
+      perMove: 1,
+      gap: 10,
+      snap: true,
+      pagination: false,
+      breakpoints: {
