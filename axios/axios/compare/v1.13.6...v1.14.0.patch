+      config: {
+        validateStatus,
+      },
+    };
+
+    settle(resolve, reject, response);
+
+    expect(validateStatus).toHaveBeenCalledOnce();
+    expect(validateStatus).toHaveBeenCalledWith(500);
+  });
+});
