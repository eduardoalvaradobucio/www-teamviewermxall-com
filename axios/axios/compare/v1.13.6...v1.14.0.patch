+      sequence += '1';
+      return config;
+    });
+
+    axios.interceptors.request.use((config) => {
+      sequence += '2';
+      return config;
+    });
+
+    axios.interceptors.request.use((config) => {
+      sequence += '3';
+      return config;
+    });
